# Cle API Anthropic (Claude) - a recuperer sur console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# Connexion PostgreSQL
DATABASE_URL=postgresql://medirdv_user:medirdv_password@db:5432/medirdv_db

# Config de l'app
APP_ENV=development

# Cle secrete pour signer les tokens JWT (change-la pour une vraie valeur aleatoire)
JWT_SECRET_KEY=change-moi-en-une-vraie-valeur-secrete

# Optionnel : notifications email reelles (mot de passe d'application Gmail)
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Optionnel : personnalisation des exports CSV/PDF
CLINIC_NAME=MediRDV
CLINIC_LOGO_PATH=